  "keyFeatures": [
    "Real-time container management with start, stop, restart, and monitoring",
    "Docker Compose stack orchestration with visual editor",
    "Git integration with webhooks and auto-sync for stack deployments",
    "Multi-environment support for local and remote Docker hosts",
    "Interactive terminal access and real-time log streaming",
    "Container file browser with upload/download capabilities",
    "Authentication via SSO (OIDC), local users, LDAP, and 2FA",
    "Role-Based Access Control (RBAC) for enterprise deployments",
    "Automated container updates with vulnerability scanning",
    "Scheduled tasks and cron job management",
    "Real-time metrics and activity dashboard",
    "Email and webhook notifications",
    "Private registry integration",
    "Network and volume management",
    "Image scanning and security analysis",
    "SQLite and PostgreSQL database support"
  ],
  "publicApiSurface": [
    "GET /api/containers - List all containers",
    "POST /api/containers/[id]/start - Start container",
    "POST /api/containers/[id]/stop - Stop container",
    "POST /api/containers/[id]/restart - Restart container",
    "DELETE /api/containers/[id] - Remove container",
    "GET /api/containers/[id]/logs - Stream container logs",
    "POST /api/containers/[id]/exec - Execute command in container",
    "GET /api/stacks - List compose stacks",
    "POST /api/stacks - Deploy new stack",
    "PUT /api/stacks/[name] - Update stack",
    "DELETE /api/stacks/[name] - Remove stack",
    "POST /api/stacks/[name]/git-sync - Sync stack from Git",
    "GET /api/images - List images",
    "POST /api/images/pull - Pull image from registry",
    "POST /api/images/push - Push image to registry",
    "POST /api/images/scan - Scan image for vulnerabilities",
    "GET /api/networks - List networks",
    "POST /api/networks - Create network",
    "GET /api/volumes - List volumes",
    "POST /api/volumes - Create volume",
    "GET /api/environments - List Docker environments",
    "POST /api/environments - Add new environment",
    "PUT /api/environments/[id] - Update environment",
    "GET /api/schedules - List scheduled tasks",
    "POST /api/schedules - Create scheduled task",
    "GET /api/activity - Get activity dashboard data",
    "GET /api/system - Get system information",
    "POST /api/auth/login - Authenticate user",
    "POST /api/auth/logout - Logout user"
  ]
}
